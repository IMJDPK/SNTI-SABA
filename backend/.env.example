# Backend environment variables
PORT=3001
NODE_ENV=production

# JWT secret for signing user/admin tokens
JWT_SECRET_KEY=replace_with_long_random_secret

# Non-production auth bypass for full preview (set false to enforce login)
DISABLE_AUTH_FOR_TESTING=true

# Admin credentials for /api/admin/login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Optional static admin API key (alternate to JWT)
ADMIN_API_KEY=

# Allowed frontend URL for CORS (Vercel, Production)
FRONTEND_URL=https://your-frontend.vercel.app
GOOGLE_CLIENT_ID=

# Gemini configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter configuration (preferred when OPENROUTER_API_KEY is set)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
